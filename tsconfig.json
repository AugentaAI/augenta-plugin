{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["bun"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "declaration": true,
    "noEmit": true
  },
  "include": ["hooks/**/*.ts", "scripts/**/*.ts", "capture/**/*.ts", "__tests__/**/*.ts"]
}
